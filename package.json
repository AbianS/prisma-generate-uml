{
  "name": "root",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "biome lint .",
    "lint:fix": "biome check . --write",
    "test": "turbo test",
    "package:extension": "turbo build && pnpm --filter prisma-generate-uml package",
    "publish:extension": "turbo build && pnpm --filter prisma-generate-uml run publish"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "turbo": "2.9.4"
  },
  "packageManager": "pnpm@10.33.0"
}
