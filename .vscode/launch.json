{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/packages/prisma-generate-uml"
      ],
      "outFiles": [
        "${workspaceFolder}/packages/prisma-generate-uml/dist/**/*.js"
      ],
      "preLaunchTask": "build"
    }
  ]
}
