{
  "name": "prisma-generate-uml",
  "displayName": "Prisma Generate UML",
  "description": "Generate UML Diagram from prisma schema",
  "version": "3.6.1",
  "icon": "media/readme/logo.png",
  "repository": "https://github.com/AbianS/prisma-generate-uml",
  "publisher": "AbianS",
  "engines": {
    "vscode": "^1.83.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "browser": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "prisma-generate-uml.generateUML",
        "title": "Generate Prisma UML",
        "icon": {
          "light": "./media/logo_light.svg",
          "dark": "./media/logo_dark.svg"
        }
      },
      {
        "command": "hello-world.showHelloWorld",
        "title": "Hello World (React + Vite): Show"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "editorLangId == prisma",
          "command": "prisma-generate-uml.generateUML",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm build",
    "build": "pnpm copy:webview && pnpm esbuild:prod && pnpm copy",
    "copy": "shx cp node_modules/@prisma/prisma-schema-wasm/src/prisma_schema_build_bg.wasm dist/",
    "copy:webview": "shx mkdir -p webview-ui/build && shx cp -r ../webview-ui/build/* webview-ui/build/",
    "esbuild": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "esbuild:prod": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify",
    "esbuild:watch": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm compile",
    "test": "vscode-test",
    "clean": "rm -rf dist webview-ui node_modules/.cache",
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@prisma/prisma-schema-wasm": "7.6.0-1.75cbdc1eb7150937890ad5465d861175c6624711",
    "@types/mocha": "10.0.10",
    "@types/node": "24.12.2",
    "@types/vscode": "1.83.0",
    "@vscode/test-cli": "0.0.12",
    "@vscode/test-electron": "2.5.2",
    "@vscode/vsce": "3.7.1",
    "esbuild": "0.28.0",
    "shx": "0.4.0",
    "typescript": "6.0.2"
  },
  "dependencies": {
    "@prisma/internals": "7.6.0"
  }
}
